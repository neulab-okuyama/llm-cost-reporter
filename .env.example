# --- Providers (set the ones you use; unset providers are skipped) ---

# OpenAI Admin key (sk-admin-...)
OPENAI_ADMIN_KEY=sk-admin-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Admin key (sk-ant-admin-...), Team/Enterprise plans
ANTHROPIC_ADMIN_KEY=sk-ant-admin-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Notifiers (set at least one) ---

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
